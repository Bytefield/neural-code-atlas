{
  "name": "@synio-es/neural-code-atlas",
  "version": "1.1.0",
  "description": "Local semantic index layer for codebases. Structural code intelligence via tree-sitter + SQLite, with MCP server for Claude Code.",
  "main": "dist/cli.js",
  "bin": {
    "nca": "dist/cli.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "README.md",
    "LICENSE",
    "INSTALL.md",
    "MCP_SETUP.md"
  ],
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "start": "node dist/cli.js",
    "mcp": "node dist/mcp.js",
    "dev": "ts-node src/cli.ts",
    "test": "node test/run.js"
  },
  "keywords": [
    "code-analysis",
    "semantic-index",
    "tree-sitter",
    "mcp",
    "claude",
    "code-intelligence",
    "typescript",
    "javascript",
    "python",
    "cli",
    "local",
    "codebase"
  ],
  "author": "Miguel Ramos <ramosperez1978@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Bytefield/neural-code-atlas.git"
  },
  "bugs": {
    "url": "https://github.com/Bytefield/neural-code-atlas/issues"
  },
  "homepage": "https://github.com/Bytefield/neural-code-atlas#readme",
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "chokidar": "^3.6.0",
    "commander": "^12.0.0",
    "tree-sitter": "^0.21.1",
    "tree-sitter-javascript": "^0.21.4",
    "tree-sitter-python": "^0.21.0",
    "tree-sitter-typescript": "^0.21.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^20.11.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
